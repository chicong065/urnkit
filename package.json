{
  "name": "urnkit",
  "version": "1.0.0",
  "description": "RFC 8141-compliant parser and serializer for Uniform Resource Names (URNs).",
  "keywords": [
    "equivalence",
    "nid",
    "normalize",
    "nss",
    "parser",
    "percent-encoding",
    "rfc-8141",
    "rfc8141",
    "serializer",
    "typescript",
    "uniform-resource-name",
    "urn",
    "urn-parser",
    "urns"
  ],
  "homepage": "https://github.com/chicong065/urnkit#readme",
  "bugs": "https://github.com/chicong065/urnkit/issues",
  "license": "MIT",
  "author": "Cong Nguyen <chicong065@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chicong065/urnkit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "bench": "vitest bench --run",
    "build": "tsdown",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm lint:fix && pnpm format",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "pnpm check && pnpm test && pnpm test:cjs && pnpm build",
    "size": "tsx bench/bundle-size.ts",
    "test": "vitest run --passWithNoTests",
    "test:cjs": "node test/smoke.cjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
}
